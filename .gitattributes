# Normalize all text files to LF on checkout
* text=auto eol=lf

# Force these to always be LF
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.env*  text eol=lf

# Binary files — no line-ending conversion
*.png   binary
*.jpg   binary
*.ico   binary
*.svg   binary
